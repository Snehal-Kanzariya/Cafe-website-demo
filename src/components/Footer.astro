---
const nav = [
  { label: 'Menu',        href: '#menu'        },
  { label: 'Our Story',   href: '#story'       },
  { label: 'Gallery',     href: '#gallery'     },
  { label: 'Reviews',     href: '#testimonials'},
  { label: 'Reserve',     href: '#reservation' },
];

const social = [
  { label: 'Instagram', href: '#', icon: 'M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z' },
  { label: 'Twitter',   href: '#', icon: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.855L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z' },
  { label: 'Facebook',  href: '#', icon: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z' },
];
---

<footer class="border-t border-stone-800/60 bg-stone-950">
  <div class="mx-auto max-w-7xl px-6">

    <!-- Top row -->
    <div class="grid grid-cols-1 gap-12 py-16 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <p class="font-serif text-3xl font-bold text-stone-100">
          Brewed <span class="text-amber-400 italic">&amp; Co.</span>
        </p>
        <p class="font-sans mt-3 text-sm leading-relaxed text-stone-500">
          Specialty coffee &amp; artisan pastries.<br />
          A space worth staying in.
        </p>
        <div class="mt-6 flex gap-3">
          {social.map(s => (
            <a
              href={s.href}
              aria-label={s.label}
              class="flex h-9 w-9 items-center justify-center rounded-full border border-stone-800 text-stone-500 transition-all duration-200 hover:border-amber-500/50 hover:text-amber-400"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d={s.icon} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="font-sans mb-5 text-xs font-semibold tracking-widest text-stone-400 uppercase">
          Explore
        </p>
        <ul class="space-y-3">
          {nav.map(n => (
            <li>
              <a
                href={n.href}
                class="font-sans text-sm text-stone-500 transition-colors hover:text-amber-400"
              >
                {n.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="font-sans mb-5 text-xs font-semibold tracking-widest text-stone-400 uppercase">
          Visit Us
        </p>
        <address class="font-sans space-y-2 text-sm not-italic text-stone-500">
          <p>12 Roastery Lane</p>
          <p>Bandra West, Mumbai 400050</p>
          <p class="mt-4">
            <a href="tel:+912240001234" class="transition-colors hover:text-amber-400">
              +91 22 4000 1234
            </a>
          </p>
          <p>
            <a href="mailto:hello@brewedandco.in" class="transition-colors hover:text-amber-400">
              hello@brewedandco.in
            </a>
          </p>
        </address>
      </div>

      <!-- Hours -->
      <div>
        <p class="font-sans mb-5 text-xs font-semibold tracking-widest text-stone-400 uppercase">
          Hours
        </p>
        <ul class="font-sans space-y-2 text-sm text-stone-500">
          <li class="flex justify-between gap-4">
            <span>Mon – Fri</span><span class="text-stone-300">7 am – 8 pm</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Saturday</span><span class="text-stone-300">8 am – 9 pm</span>
          </li>
          <li class="flex justify-between gap-4">
            <span>Sunday</span><span class="text-stone-300">9 am – 6 pm</span>
          </li>
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col items-center justify-between gap-4 border-t border-stone-800/60 py-6 sm:flex-row">
      <p class="font-sans text-xs text-stone-600">
        &copy; 2025 Brewed &amp; Co. All rights reserved.
      </p>
      <p class="font-sans text-xs text-stone-700">
        Crafted with care — built with Astro &amp; TailwindCSS
      </p>
    </div>

  </div>
</footer>
