---
// ── Coffee bean data ──────────────────────────────────────────────────────────
// Each bean: { left, bottom, w(px), h(px), op(acity), delay, dur(ation),
//              drift(px, + right / - left), sr(start-rotate), er(end-rotate), color }
// Beans span the full width and start at various heights so they're already
// mid-flight when the page loads — gives instant ambient density.

interface Bean {
  left: string; bottom: string;
  w: number;    h: number;
  op: number;
  delay: string; dur: string;
  drift: string;
  sr: string;   er: string;
  body: string; seam: string; hi: string;
}

// Three roast shades for visual variety
const roasts = [
  { body: '#6b3a1f', seam: '#3d1f0a', hi: '#9b6040' }, // medium
  { body: '#7c4a2a', seam: '#4a2810', hi: '#a87050' }, // light
  { body: '#5a2e14', seam: '#311808', hi: '#7c4c2c' }, // dark
] as const;

const beans: Bean[] = [
  { left: '5%',  bottom: '8%',  w: 10, h: 16, op: 0.20, delay: '0s',    dur: '13s', drift: '14px',  sr: '15deg',  er: '195deg',  ...roasts[0] },
  { left: '13%', bottom: '48%', w: 13, h: 21, op: 0.22, delay: '3.2s',  dur: '11s', drift: '-16px', sr: '-20deg', er: '-230deg', ...roasts[1] },
  { left: '21%', bottom: '18%', w: 11, h: 17, op: 0.17, delay: '7.4s',  dur: '14s', drift: '8px',   sr: '40deg',  er: '220deg',  ...roasts[2] },
  { left: '31%', bottom: '62%', w: 10, h: 16, op: 0.15, delay: '1.6s',  dur: '12s', drift: '-20px', sr: '-10deg', er: '-170deg', ...roasts[0] },
  { left: '40%', bottom: '4%',  w: 15, h: 24, op: 0.18, delay: '5.8s',  dur: '15s', drift: '16px',  sr: '28deg',  er: '250deg',  ...roasts[1] },
  { left: '50%', bottom: '35%', w: 11, h: 18, op: 0.20, delay: '9.6s',  dur: '11s', drift: '-10px', sr: '-38deg', er: '-205deg', ...roasts[2] },
  { left: '60%', bottom: '14%', w: 13, h: 21, op: 0.22, delay: '2.2s',  dur: '13s', drift: '18px',  sr: '12deg',  er: '192deg',  ...roasts[0] },
  { left: '70%', bottom: '55%', w: 10, h: 16, op: 0.16, delay: '6.5s',  dur: '12s', drift: '-13px', sr: '-48deg', er: '-218deg', ...roasts[1] },
  { left: '79%', bottom: '28%', w: 12, h: 19, op: 0.15, delay: '4.3s',  dur: '14s', drift: '7px',   sr: '33deg',  er: '213deg',  ...roasts[2] },
  { left: '87%', bottom: '42%', w: 15, h: 24, op: 0.20, delay: '11.8s', dur: '15s', drift: '-16px', sr: '-25deg', er: '-242deg', ...roasts[0] },
  { left: '93%', bottom: '6%',  w: 10, h: 16, op: 0.17, delay: '8.9s',  dur: '12s', drift: '11px',  sr: '55deg',  er: '235deg',  ...roasts[1] },
  { left: '55%', bottom: '72%', w: 12, h: 19, op: 0.14, delay: '14.5s', dur: '13s', drift: '-8px',  sr: '-18deg', er: '-188deg', ...roasts[2] },
  { left: '25%', bottom: '82%', w: 13, h: 21, op: 0.16, delay: '0.7s',  dur: '11s', drift: '14px',  sr: '22deg',  er: '202deg',  ...roasts[0] },
  { left: '46%', bottom: '88%', w: 10, h: 16, op: 0.18, delay: '10.3s', dur: '14s', drift: '-18px', sr: '-32deg', er: '-222deg', ...roasts[1] },
];
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden bg-stone-950"
>
  <!-- Layered gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-stone-950 via-amber-950/30 to-stone-950"></div>

  <!-- Ambient glow blobs -->
  <div class="pointer-events-none absolute -right-32 top-1/4 h-[520px] w-[520px] rounded-full bg-amber-700/20 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-24 h-[420px] w-[420px] rounded-full bg-amber-900/25 blur-3xl"></div>
  <div class="pointer-events-none absolute left-1/3 top-16 h-64 w-64 rounded-full bg-amber-600/10 blur-2xl"></div>

  <!-- ── Floating coffee beans ───────────────────────────────── -->
  <!--
    z-[1]: sits above gradient (z-0) but well below content (z-10).
    Each bean carries CSS custom properties consumed by bean-rise keyframe:
      --op    peak opacity
      --drift horizontal travel (positive = right, negative = left)
      --sr    rotation at start
      --er    rotation at end (full rotation adds life without being distracting)
  -->
  <div
    class="pointer-events-none absolute inset-0 z-[1] overflow-hidden"
    aria-hidden="true"
  >
    {beans.map(b => (
      <div
        class="bean absolute"
        style={`
          left:${b.left};
          bottom:${b.bottom};
          width:${b.w}px;
          height:${b.h}px;
          --op:${b.op};
          --drift:${b.drift};
          --sr:${b.sr};
          --er:${b.er};
          animation:bean-rise ${b.dur} ${b.delay} ease-in-out infinite;
          will-change:transform,opacity;
        `}
      >
        <!--
          SVG coffee bean:
          - Outer ellipse   → bean body
          - S-curve path    → the natural seam/groove
          - Inner ellipse   → top-left specular highlight
        -->
        <svg
          viewBox="0 0 24 36"
          width="100%"
          height="100%"
          xmlns="http://www.w3.org/2000/svg"
        >
          <ellipse cx="12" cy="18" rx="11" ry="17" fill={b.body} />
          <path
            d="M12 4 C 8 10, 16 16, 12 22 C 8 28, 16 32, 12 34"
            stroke={b.seam}
            stroke-width="1.8"
            stroke-linecap="round"
            fill="none"
          />
          <ellipse cx="8" cy="12" rx="2.5" ry="4.5" fill={b.hi} opacity="0.42" />
        </svg>
      </div>
    ))}
  </div>

  <!-- Main content -->
  <div class="relative z-10 mx-auto max-w-5xl px-6 text-center">

    <!-- Eyebrow label -->
    <div class="mb-8 inline-flex items-center gap-3">
      <span class="h-px w-12 bg-amber-500/50"></span>
      <span class="font-sans text-xs font-medium tracking-[0.35em] text-amber-400 uppercase">
        Specialty Coffee · Artisan Pastries
      </span>
      <span class="h-px w-12 bg-amber-500/50"></span>
    </div>

    <!-- Display headline -->
    <h1 class="font-serif mb-8 text-[5rem] font-bold leading-[0.88] tracking-tight sm:text-[7rem] md:text-[10rem]">
      <span class="text-stone-100">Brewed</span>
      <br />
      <span class="italic text-amber-400">&amp; Co.</span>
    </h1>

    <!-- Tagline -->
    <p class="font-sans mx-auto mb-12 max-w-2xl text-lg font-light leading-relaxed text-stone-400 sm:text-xl md:text-2xl">
      Where every cup tells a story. Premium single-origin coffee,
      house-baked pastries, and spaces designed for
      <em class="not-italic text-stone-200">meaningful moments.</em>
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#menu"
        class="font-sans rounded-full bg-amber-500 px-10 py-4 text-sm font-semibold tracking-wide text-stone-950 transition-all duration-300 hover:scale-105 hover:bg-amber-400 hover:shadow-xl hover:shadow-amber-500/25"
      >
        Explore Menu
      </a>
      <a
        href="#reservation"
        class="font-sans rounded-full border border-stone-700 px-10 py-4 text-sm font-medium tracking-wide text-stone-300 transition-all duration-300 hover:border-amber-500/60 hover:text-amber-400"
      >
        Reserve a Table →
      </a>
    </div>

    <!-- Stats row -->
    <div class="mt-20 flex flex-wrap justify-center gap-10 sm:gap-16">
      {[
        { value: '6+',   label: 'Years of craft'     },
        { value: '12',   label: 'Single-origin beans' },
        { value: '40+',  label: 'Menu items'          },
        { value: '4.9★', label: 'Guest rating'        },
      ].map(stat => (
        <div class="text-center">
          <p class="font-serif text-3xl font-bold text-amber-400">{stat.value}</p>
          <p class="font-sans mt-1 text-xs tracking-widest text-stone-500 uppercase">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Scroll nudge -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-stone-600">
    <svg width="20" height="28" viewBox="0 0 20 28" fill="none" stroke="currentColor" stroke-width="1.5">
      <rect x="1" y="1" width="18" height="24" rx="9" stroke-opacity="0.4"/>
      <line x1="10" y1="7" x2="10" y2="12" stroke-linecap="round"/>
    </svg>
  </div>
</section>

<style>
  /*
   * bean-rise — the only keyframe needed.
   * Per-bean variation is handled entirely by CSS custom properties
   * set as inline styles on each .bean element:
   *
   *   --op     peak opacity    (e.g. 0.20)
   *   --drift  horizontal travel (e.g. "14px" or "-16px")
   *   --sr     start rotation  (e.g. "15deg")
   *   --er     end rotation    (e.g. "195deg")
   *
   * The browser resolves var() at computed-value time, giving the
   * animation engine concrete values to interpolate between.
   */
  @keyframes bean-rise {
    0% {
      transform: translateY(0) translateX(0) rotate(var(--sr));
      opacity: 0;
    }
    10% {
      opacity: var(--op);
    }
    88% {
      opacity: var(--op);
    }
    100% {
      transform: translateY(-108vh) translateX(var(--drift)) rotate(var(--er));
      opacity: 0;
    }
  }

  .bean {
    transform-origin: center center;
  }
</style>
