---
// Reservation CTA section
---

<section id="reservation" class="bg-stone-950 py-24">
  <div class="mx-auto max-w-5xl px-6">

    <!-- Decorative card -->
    <div class="relative overflow-hidden rounded-3xl border border-amber-500/20 bg-gradient-to-br from-amber-950/60 via-stone-900 to-stone-950 p-10 text-center sm:p-16">

      <!-- Background glow -->
      <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-amber-600/15 blur-3xl"></div>
      <div class="pointer-events-none absolute -bottom-16 -left-16 h-64 w-64 rounded-full bg-amber-900/20 blur-3xl"></div>

      <!-- Content -->
      <div class="relative z-10">
        <p class="font-sans mb-6 text-xs font-medium tracking-[0.35em] text-amber-400 uppercase">
          Join Us
        </p>
        <h2 class="font-serif mb-6 text-5xl font-bold leading-tight text-stone-100 sm:text-6xl">
          Reserve your table
        </h2>
        <p class="font-sans mx-auto mb-10 max-w-lg text-lg leading-relaxed text-stone-400">
          Whether it's a slow Saturday morning or a weekday catch-up — we'd love to
          have you. Walk-ins always welcome; reservations ensure your favourite spot.
        </p>

        <!-- Simple inline form -->
        <form class="mx-auto flex max-w-2xl flex-col gap-3 sm:flex-row">
          <input
            type="text"
            placeholder="Your name"
            class="font-sans flex-1 rounded-full border border-stone-700/60 bg-stone-900/80 px-5 py-4 text-sm text-stone-100 placeholder-stone-500 outline-none transition-colors focus:border-amber-500/60 focus:ring-0"
          />
          <input
            type="date"
            class="font-sans rounded-full border border-stone-700/60 bg-stone-900/80 px-5 py-4 text-sm text-stone-400 outline-none transition-colors focus:border-amber-500/60 [color-scheme:dark]"
          />
          <button
            type="submit"
            class="font-sans rounded-full bg-amber-500 px-8 py-4 text-sm font-semibold text-stone-950 transition-all duration-200 hover:scale-105 hover:bg-amber-400 hover:shadow-lg hover:shadow-amber-500/25"
          >
            Book Now
          </button>
        </form>

        <!-- Hours -->
        <div class="mt-12 flex flex-wrap justify-center gap-8 border-t border-stone-800/60 pt-10">
          {[
            { days: 'Mon – Fri', hours: '7 am – 8 pm' },
            { days: 'Saturday',  hours: '8 am – 9 pm' },
            { days: 'Sunday',    hours: '9 am – 6 pm' },
          ].map(h => (
            <div class="text-center">
              <p class="font-sans text-xs font-medium tracking-widest text-amber-400 uppercase">{h.days}</p>
              <p class="font-serif mt-1 text-xl font-bold text-stone-200">{h.hours}</p>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
